DeferredRenderer renderer;

Camera cam = make_camera(90 * deg2rad, 0.1, 10000);

void mesh_load(char* full_path) {
    OBJ_Data obj = load_obj(full_path);

    string path = alloc_string_copy(full_path); // full_path may be a temorary string allocation (temp_builder) an therefore gets invalid at some point through the for loop
    string file_name;
    decompose_path(path, null, *file_name, null);

    for 0 .. list_length(obj.objects) {
        OBJ_Object o = obj.objects[it];

        Mesh* mesh = mesh_alloc();
        mesh.name = alloc_string_copy(concat(file_name, make_string("."), o.name));

        obj_to_mesh(obj, mesh, o.indices_length, o.indices_start);

        set_origin(mesh, avg_vertex_pos(mesh));
        gen_normals(mesh);
        calc_bounds(mesh);

        list_add(*all_meshes, *mesh);
    }

    free(path.chars);

    free_obj(obj);
}

