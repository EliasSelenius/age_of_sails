
include "../grax/grax.pog";

include "kmeans.pog";

// ..\plang\bin\plang.exe src\main.pog cflags -lglfw3dll

/*


porting 'c_opengl' (the boat game) to plang:
    <Done> - meshes
    <Done> - OBJ importing
    <Done> - UBO
    <Done> - shader include directive
    <Done> - framebuffers
    <Done> - deffered rendering system
    - PBR
    <Done> - camera math
    - physics
    <Done> - water rendering (gerstner waves)
    <Done> - water rendering (semi transparancy)
    <Done> - gizmo point rendering
    - skybox

