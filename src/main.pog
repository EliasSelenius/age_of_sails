Capsule Capsule_Human = {
    a = vec3_zero,
    b = {0, 1.33, 0}, // 1.33 = 1.83 - 2*0.25
    radius = 0.25
};

struct Capsule {
    vec3 a, b;
    float32 radius;
}

Capsule boat_collider_from_mesh(Mesh* m) {
    Capsule c = {};
    c.radius = m.bb_max.x;
    c.a.z = m.bb_min.z + c.radius;
    c.b.z = m.bb_max.z - c.radius;

    c.a.y = m.bb_min.y + c.radius;
    c.b.y = m.bb_min.y + c.radius;

    return c;
}

